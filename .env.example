# Lifesight OpenUI POC — Environment Variables
#
# This POC runs entirely on fixture data — no environment variables are required
# to start the dev server. All variables below are for the production integration
# hook points documented in docs/integration-roadmap.md.

# ── Production agent backend (Path A — 3.0 migration hook) ───────────────────
# VITE_AGENT_ENDPOINT=https://your-agent-service/api/v1/agent/chat
# Maps to: fetch(VITE_AGENT_ENDPOINT, { method: "POST", body: { message, sessionId } })
# Replace createFakeSSEStream() in src/mocks/sseStream.ts with this endpoint.

# ── Production agent backend (Path B — 4.0 MIA/Decision Room hook) ───────────
# VITE_MIA_ENDPOINT=https://your-mia-service/api/v1/mia/invoke
# VITE_DECISION_ENDPOINT=https://your-decision-service/api/v1/decisions

# ── Feature flags ─────────────────────────────────────────────────────────────
# VITE_STREAM_DEFAULT=false   # Set to true to default all routes to stream mode
# VITE_MERMAID_ENABLED=true   # Set to false to disable Mermaid rendering (bundle savings)
